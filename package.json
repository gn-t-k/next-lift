{
	"name": "next-lift",
	"version": "0.1.0",
	"private": true,
	"description": "ウェイトトレーニングの計画と記録を行うアプリケーション",
	"op-sqlite": {
		"libsql": true
	},
	"scripts": {
		"build": "turbo build",
		"dev": "turbo dev",
		"lint": "turbo lint",
		"lint:root": "biome check .claude .mcp.json renovate.json biome.jsonc package.json turbo.json",
		"type-check": "turbo type-check",
		"test": "turbo test",
		"clean": "turbo clean",
		"worktree:copy-env": "bash .claude/scripts/copy-worktree-env.sh",
		"setup:worktree": "bash .claude/scripts/setup-worktree.sh"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@turbo/gen": "2.9.16",
		"turbo": "2.9.16",
		"vercel": "54.6.1"
	},
	"packageManager": "pnpm@10.33.4",
	"engines": {
		"node": ">=18.0.0"
	}
}
